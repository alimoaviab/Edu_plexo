# ═══════════════════════════════════════════════════════════════════════════
# EduPlexo — VPS Production Environment
# ═══════════════════════════════════════════════════════════════════════════
# Generate secrets: openssl rand -base64 32
# NEVER commit this file with real values to git.

# ─── App ──────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=school
PORT=8080

# ─── Domain ───────────────────────────────────────────────────────────────
DOMAIN=eduplexo.com
API_DOMAIN=api.eduplexo.com
CERTBOT_EMAIL=admin@eduplexo.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=eduplexo_prod
POSTGRES_USER=eduplexo_app
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_24

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_32
COOKIE_SECURE=true

# ─── CORS (Vercel frontend domains) ──────────────────────────────────────
ALLOWED_ORIGINS=https://app.eduplexo.com,https://admin.eduplexo.com,https://eduplexo.com

# ─── Super Admin ──────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=eduplexo@gmail.com
DEFAULT_ADMIN_PASS=CHANGE_ME_STRONG_PASSWORD

# ─── AI (Gemini) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=10

# ─── AI Fallback (OpenRouter) ────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001

# ─── Plexa Chatbot ───────────────────────────────────────────────────────
GO_BACKEND_TIMEOUT=8
SESSION_TTL_SECONDS=1800
MAX_HISTORY_PAIRS=10
RATE_LIMIT_PER_MINUTE=20

# ─── Go Runtime ──────────────────────────────────────────────────────────
GOMAXPROCS=2
GOMEMLIMIT=512MiB
