# ═══════════════════════════════════════════════════════════════════════════
# EduPlexo VPS Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file: cp .env.vps.example .env.vps
# Then fill in your actual values

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=eduplexo_prod
POSTGRES_USER=eduplexo_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Application ──────────────────────────────────────────────────────────
APP_ENV=production
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
ALLOWED_ORIGINS=https://app.eduplexo.com,https://admin.eduplexo.com
COOKIE_SECURE=true

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── AI Providers ────────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_YOUR_API_KEY
GEMINI_MODEL=gemini-2.5-flash
