# Copy this file to `.env` and set your machine's LAN IP.
#   cp .env.example .env
#   ipconfig getifaddr en0   # <- shows your Mac's Wi-Fi IP
#
# Physical device / same Wi-Fi as the Mac running the Docker backend:
EXPO_PUBLIC_API_URL=http://192.168.1.100:8080/api
#
# Android emulator (host loopback):
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api
#
# Leave unset to use the production default from app.json
# (https://api.eduplexo.com/api).
