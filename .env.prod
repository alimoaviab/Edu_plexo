# Eduplexo production environment template.
# Copy this file outside version control and fill values from your secret manager.
# Never commit real production secrets.

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=eduplexo_prod
POSTGRES_USER=eduplexo_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_FROM_SECRET_MANAGER

# ─── Application ──────────────────────────────────────────────────────────
APP_ENV=production
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
ALLOWED_ORIGINS=https://app.eduplexo.com,https://admin.eduplexo.com
COOKIE_SECURE=true

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_FROM_SECRET_MANAGER

# ─── Domain ──────────────────────────────────────────────────────────────
DOMAIN=eduplexo.com

# ─── Google Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY_FROM_SECRET_MANAGER
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY_FROM_SECRET_MANAGER
