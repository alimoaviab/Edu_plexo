# ═══════════════════════════════════════════════════════════════════════════
# Eduplexo Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=eduplexo_prod
POSTGRES_USER=eduplexo_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── Application ──────────────────────────────────────────────────────────
APP_ENV=production
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
ALLOWED_ORIGINS=https://app.eduplexo.com,https://admin.eduplexo.com
COOKIE_SECURE=true

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Domain ──────────────────────────────────────────────────────────────
DOMAIN=eduplexo.com

# ─── AI Providers ────────────────────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
