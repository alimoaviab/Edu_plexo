<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Drawn before Flutter renders the first frame.
         Prevents the white flash on cold start. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/brandPrimary</item>
        <item name="android:navigationBarColor">@color/brandPrimary</item>
    </style>

    <!-- Used after Flutter is up so config-change rotations don't flash. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
