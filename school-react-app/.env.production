# School App Production Environment (Vercel)

# Base URL of the deployed Go backend API
# This points to your VPS backend
VITE_API_URL=http://api.eduplexo.com

# App metadata
VITE_APP_NAME=Eduplexo — School Workspace
VITE_APP_DESCRIPTION=Multi-school SaaS school workspace

# Disable mocks in production
VITE_ENABLE_MOCKS=false
